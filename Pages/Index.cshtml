@page
@model IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Home";
}

@section Head {
<meta name="description" content="New Bethel Missionary Baptist Church — Winter Haven, Florida. A cornerstone of faith and community for generations.">
<link rel="preload" as="video" type="video/mp4" href="~/videos/motionglass.mp4" asp-append-version="true" />
<link rel="stylesheet" href="~/css/pages/index.css" asp-append-version="true" />
}

<!-- ══════════════════ HERO (viewport = video + text only — same model as About/Give) ══════════════════ -->
<div class="hero-section">

  <div class="home-hero-viewport">
    <div class="hero-bg-wrap" id="heroBgWrap">
      <video
        class="hero-video"
        autoplay muted loop playsinline
        preload="auto">
        <source src="/videos/motionglass.mp4" type="video/mp4">
      </video>
    </div>
    <div class="hero-text-wrap">
      <div class="hero-scripture" lang="en">
        <h1 class="hero-scripture-title">
          <span class="word"><span class="hero-text-judson">I can do all things through Christ</span><span class="hero-text-lora"> which strengtheneth me.</span></span>
        </h1>
        <p class="hero-scripture-ref"><span class="word">Philippians 4:13</span></p>
      </div>
    </div>
  </div>

  <!-- WHITE CARD LIFT -->
  <div class="white-lift">

    <!-- ══ SECTION 1: WHITE ══ -->
    <section class="section-white" id="about">
      <div class="section-inner">

        <!-- Row 1: Image + About text -->
        <div class="row reveal">
          <div class="row-img" style="aspect-ratio: 0.75;">
            <div class="row-img-ph">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              Add congregation photo
            </div>
          </div>
          <div class="row-text">
            <h2 class="s-h2">A church where all are welcome.</h2>
            <p class="s-body">
              <strong>Our Story</strong><br><br>
              Rooted in faith, growing together.<br><br>
              New Bethel Missionary Baptist Church has been a cornerstone of faith and community for generations. We are a church family committed to the gospel of Jesus Christ — worshipping boldly, serving humbly, and loving without condition.
            </p>
            <a href="/About" class="ulink">
              LEARN ABOUT US
              <span class="ucircle">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>
        </div>

        <!-- Row 2: Values text + small image + faith phrases -->
        <div class="values-row reveal">
          <div class="values-right-text">
            <p class="s-body"><strong>NEW BETHEL MISSIONARY BAPTIST CHURCH</strong> — A place to belong, believe, and become.</p>
          </div>
          <div class="inline-img">
            <div class="inline-img-ph">Add photo</div>
          </div>
          <div class="faith-phrases">
            <h2 class="s-h2" style="line-height: 1.05;">
              <span class="accent-text">Love</span> God.<br>
              <span class="accent-text">Faith</span> Build.<br>
              <span class="accent-text">Hope</span> Filled.
            </h2>
          </div>
        </div>

      </div>
    </section>

    <!-- ══ SECTION 2: GRAY ══ -->
    <section class="section-gray" id="ministries">
      <div class="section-inner">

        <!-- Block 1: Wide image + ministry text -->
        <div class="wide-row reveal">
          <div class="wide-img">
            <div class="wide-img-ph">Add ministry / outreach photo</div>
          </div>
          <div class="wide-text">
            <h3 class="s-h3"><strong>IN THE ROOM, IN THE CITY + IN THE WORLD.</strong></h3>
            <p class="s-body">Dive into Bible teaching, lessons, and inspiring online content to grow your faith and understanding.</p>
            <a href="https://www.youtube.com/@@NewBethelMissionaryBaptist" target="_blank" rel="noopener" class="ulink">
              FIND OUT MORE
              <span class="ucircle">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>
        </div>

        <!-- Block 2: 3-column cards -->
        <div class="cards-row" id="events">

          <!-- Card 1: Who Jesus Is -->
          <div class="card-col reveal">
            <div class="card-img">
              <div class="card-img-ph">Add photo</div>
            </div>
            <h3 class="s-h3">Who Jesus is.</h3>
            <p class="s-body">Discover who Jesus is, what He taught, and how His love continues to transform lives, guiding us toward hope, purpose, and faith every day.</p>
            <a href="/Jesus" class="ulink" style="font-size: 14px;">
              LEARN JESUS
              <span class="ucircle" style="width:16px;height:16px;">
                <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>

          <!-- Card 2: Events -->
          <div class="card-col reveal d1">
            <div class="card-img">
              <div class="card-img-ph">Add photo</div>
            </div>
            <h3 class="s-h3">Edifying events.</h3>
            <p class="s-body">Explore our events calendar to see what's happening this month. Join us for praise, workshops, and community moments and discover ways to get involved.</p>
            <a href="/Events" class="ulink" style="font-size: 14px;">
              SEE EVENTS
              <span class="ucircle" style="width:16px;height:16px;">
                <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>

          <!-- Card 3: Give -->
          <div class="card-col reveal d2">
            <div class="card-img">
              <div class="card-img-ph">Add photo</div>
            </div>
            <h3 class="s-h3">Give for growth.</h3>
            <p class="s-body">Your generosity helps us carry out our mission, support our community, and make a lasting impact. Every gift, big or small, contributes to the work God is doing through us.</p>
            <a href="/Give" class="ulink" style="font-size: 14px;">
              GIVE NOW
              <span class="ucircle" style="width:16px;height:16px;">
                <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>

        </div>

      </div>

      <!-- BIG CTA -->
      <a href="/Events" class="big-cta reveal" style="text-decoration: none; margin-top: 150px;">
        <span class="big-cta-text">See what's on.</span>
        <div class="big-cta-circle">
          <svg width="80" height="80" viewBox="0 0 144 144" fill="none" stroke="black" stroke-width="10" stroke-linecap="square">
            <path d="M 84 36 L 120 72 L 84 108 M 114 72 L 24 72"/>
          </svg>
        </div>
      </a>

    </section>

  </div><!-- end white-lift -->
</div><!-- end hero-section -->

@section Scripts {
<script src="~/js/hero-video-env.js" asp-append-version="true"></script>
<script src="~/js/pages/index.js" asp-append-version="true"></script>
}
