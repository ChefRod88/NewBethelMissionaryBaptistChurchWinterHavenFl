@page
@model ChurchWebsite.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Events";
}

@section Head {
<meta name="description" content="Upcoming events at New Bethel Missionary Baptist Church — Winter Haven, Florida.">
<link rel="preload" as="video" type="video/mp4" href="~/videos/thanks.mp4" asp-append-version="true" />
<link rel="stylesheet" href="~/css/pages/events-index.css" asp-append-version="true" />
}

<!-- PAGE HEADER (video background; no dark overlay) -->
<div class="ev-page-header" aria-label="Events">
  <h1 class="visually-hidden">@ViewData["Title"]</h1>
  <div class="ev-page-header-bg" id="eventsHeroBg">
    <video
      class="ev-hero-video"
      src='@Url.Content("~/videos/thanks.mp4")'
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"></video>
  </div>
</div>

<!-- WHITE CARD LIFT -->
<div class="ev-white-lift">

  <div class="ev-content">
    <section class="ev-beacon" aria-labelledby="bethelBeaconHeading">
      <p class="ev-beacon-label">Bethel Beacon</p>

      @if (Model.HasCurrentBeacon)
      {
        <div class="ev-beacon-intro">
          <div>
            <h2 id="bethelBeaconHeading" class="ev-beacon-heading">This Week&apos;s Bethel Beacon</h2>
            <p class="ev-beacon-body">
              Read the latest announcements, ministry updates, and weekly activities from New Bethel.
              Tap any page to open a larger view that is easier to read on mobile devices.
            </p>
          </div>

          <p class="ev-beacon-date">Current issue: @Model.CurrentBeacon!.DisplayDate</p>
        </div>

        <div class="ev-beacon-grid">
          <article class="ev-beacon-card">
            <button
              type="button"
              class="ev-beacon-preview"
              data-beacon-open="front"
              aria-label="Open the Bethel Beacon front page">
              <img
                class="ev-beacon-image"
                src="@Model.CurrentBeacon.Front.Url"
                alt="@Model.CurrentBeacon.Front.AltText"
                loading="lazy" />
            </button>

            <div class="ev-beacon-card-body">
              <div>
                <p class="ev-beacon-card-label">Front page</p>
                <h3 class="ev-beacon-card-title">Announcements and highlights</h3>
              </div>

              <div class="ev-beacon-actions">
                <button type="button" class="ev-beacon-open" data-beacon-open="front">View full size</button>
                <a href="@Model.CurrentBeacon.Front.Url" class="ev-beacon-link" target="_blank" rel="noopener noreferrer">Open original JPG</a>
              </div>
            </div>
          </article>

          <article class="ev-beacon-card">
            <button
              type="button"
              class="ev-beacon-preview"
              data-beacon-open="back"
              aria-label="Open the Bethel Beacon back page">
              <img
                class="ev-beacon-image"
                src="@Model.CurrentBeacon.Back.Url"
                alt="@Model.CurrentBeacon.Back.AltText"
                loading="lazy" />
            </button>

            <div class="ev-beacon-card-body">
              <div>
                <p class="ev-beacon-card-label">Back page</p>
                <h3 class="ev-beacon-card-title">Weekly schedule and community details</h3>
              </div>

              <div class="ev-beacon-actions">
                <button type="button" class="ev-beacon-open" data-beacon-open="back">View full size</button>
                <a href="@Model.CurrentBeacon.Back.Url" class="ev-beacon-link" target="_blank" rel="noopener noreferrer">Open original JPG</a>
              </div>
            </div>
          </article>
        </div>

        <div
          id="bethelBeaconModal"
          class="ev-beacon-modal"
          role="dialog"
          aria-modal="true"
          aria-labelledby="bethelBeaconModalTitle"
          hidden
          data-front-src="@Model.CurrentBeacon.Front.Url"
          data-front-alt="@Model.CurrentBeacon.Front.AltText"
          data-back-src="@Model.CurrentBeacon.Back.Url"
          data-back-alt="@Model.CurrentBeacon.Back.AltText"
          data-issue-date="@Model.CurrentBeacon.DisplayDate">
          <button type="button" class="ev-beacon-modal-overlay" data-beacon-close aria-label="Close the Bethel Beacon viewer"></button>

          <div class="ev-beacon-modal-card">
            <button type="button" class="ev-beacon-modal-close" data-beacon-close aria-label="Close the Bethel Beacon viewer">&times;</button>

            <div class="ev-beacon-modal-header">
              <p class="ev-beacon-modal-label">Bethel Beacon</p>
              <h3 id="bethelBeaconModalTitle" class="ev-beacon-modal-title">Current issue</h3>
              <p class="ev-beacon-modal-date">@Model.CurrentBeacon.DisplayDate</p>
            </div>

            <div class="ev-beacon-modal-body">
              <button type="button" class="ev-beacon-modal-nav" data-beacon-nav="prev" aria-label="View the previous Bethel Beacon page">
                <span aria-hidden="true">&larr;</span>
              </button>

              <div class="ev-beacon-modal-stage">
                <p id="bethelBeaconModalPageLabel" class="ev-beacon-modal-page"></p>
                <img id="bethelBeaconModalImage" class="ev-beacon-modal-image" src="" alt="" />
              </div>

              <button type="button" class="ev-beacon-modal-nav" data-beacon-nav="next" aria-label="View the next Bethel Beacon page">
                <span aria-hidden="true">&rarr;</span>
              </button>
            </div>
          </div>
        </div>
      }
      else
      {
        <div class="ev-beacon-empty">
          <h2 id="bethelBeaconHeading" class="ev-beacon-heading">Bethel Beacon coming soon</h2>
          <p class="ev-beacon-body">
            Once the latest bulletin scans are uploaded, you&apos;ll be able to read the current Bethel Beacon
            here on the Events page.
          </p>
        </div>
      }
    </section>
  </div>

  <!-- BIG CTA -->
  <a href="/#about" class="ev-big-cta">
    <span class="ev-big-cta-text">Join the family.</span>
    <div class="ev-big-cta-circle">
      <svg width="80" height="80" viewBox="0 0 144 144" fill="none" stroke="black" stroke-width="10" stroke-linecap="square">
        <path d="M 84 36 L 120 72 L 84 108 M 114 72 L 24 72"/>
      </svg>
    </div>
  </a>

</div><!-- end white-lift -->

@section Scripts {
<script src="~/js/hero-video-env.js" asp-append-version="true"></script>
<script src="~/js/pages/events-index.js" asp-append-version="true"></script>
}
