@page
@model ChurchWebsite.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Events";
}

@section Head {
<meta name="description" content="Upcoming events at New Bethel Missionary Baptist Church — Winter Haven, Florida.">
<link rel="stylesheet" href="~/css/pages/events-index.css" asp-append-version="true" />
}

<!-- PAGE HEADER (video background; no dark overlay) -->
<div class="ev-page-header" aria-label="Events">
  <h1 class="visually-hidden">@ViewData["Title"]</h1>
  <div class="ev-page-header-bg" id="eventsHeroBg">
    <video
      class="ev-hero-video"
      src='@Url.Content("~/videos/thanks.mp4")'
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"></video>
  </div>
</div>

<!-- WHITE CARD LIFT -->
<div class="ev-white-lift">

  <div class="ev-content">
    <div class="ev-tba">
      <p class="ev-tba-label">Upcoming Events</p>
      <h2 class="ev-tba-heading">To Be Announced.</h2>
      <p class="ev-tba-body">We're planning something special. Check back soon for events,<br>gatherings, and ways to connect with our community.</p>
    </div>
  </div>

  <!-- BIG CTA -->
  <a href="/#about" class="ev-big-cta">
    <span class="ev-big-cta-text">Join the family.</span>
    <div class="ev-big-cta-circle">
      <svg width="80" height="80" viewBox="0 0 144 144" fill="none" stroke="black" stroke-width="10" stroke-linecap="square">
        <path d="M 84 36 L 120 72 L 84 108 M 114 72 L 24 72"/>
      </svg>
    </div>
  </a>

</div><!-- end white-lift -->

@section Scripts {
<script src="~/js/pages/events-index.js" asp-append-version="true"></script>
}
