@page
@inject IOptions<ChurchSettings> ChurchOptions
@{
    Layout = "_Layout";
    ViewData["Title"] = "Give";
    ViewData["Description"] = "Give to New Bethel Missionary Baptist Church. Your generosity helps us carry out our mission and support our community.";
    var church = ChurchOptions.Value;
}

@section Head {
<meta name="description" content="Give to New Bethel Missionary Baptist Church. Your generosity helps us carry out our mission and support our community.">
<style>
/* ── TOKENS ── */
:root {
  --white: #ffffff;
  --bg: #ededed;
  --black: #000000;
  --accent: #2a967d;
  --gray: #949494;
  --gray-dark: #474747;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
body { font-family: 'Outfit', sans-serif; background: var(--bg); color: var(--black); overflow-x: hidden; }

/* ── HERO (same stacking model as home page: bg wrap + absolute text layer) ── */
.give-hero-section {
  --give-hero-h: 75vh;
  --give-hero-minh: 500px;
  position: relative;
  width: 100%;
  background: #000;
}
.give-hero-bg-wrap {
  width: 100%;
  height: var(--give-hero-h);
  min-height: var(--give-hero-minh);
  position: relative;
  overflow: hidden;
  background: #000;
}
.give-hero-bg-wrap.is-fallback {
  background: linear-gradient(160deg, #1a1520 0%, #2a1f35 50%, #1a2030 100%);
}
.give-hero-bg-wrap.is-fallback .give-hero-video {
  display: none;
}
.give-hero-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  pointer-events: none;
  will-change: transform;
}
.give-hero-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: rgba(0, 0, 0, 0.38);
  pointer-events: none;
}
.give-hero-text-wrap {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: var(--give-hero-h);
  min-height: var(--give-hero-minh);
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}
.give-hero-text-inner {
  max-width: 900px;
  padding: 0 24px;
}
.give-hero-title {
  font-family: 'Judson', serif; font-style: italic;
  font-size: clamp(80px, 15vw, 240px);
  letter-spacing: -0.06em; line-height: 0.85em;
  color: var(--white);
  text-shadow: 0 0 50px rgba(0,0,0,0.5);
}
.give-hero-title strong { font-style: normal; font-weight: 700; }
.give-hero-tagline {
  font-family: 'Judson', serif;
  font-size: clamp(22px, 3.5vw, 40px);
  font-weight: 400;
  letter-spacing: -0.03em;
  line-height: 1.2;
  color: var(--white);
  margin-top: 1.25rem;
  text-shadow: 0 2px 24px rgba(0,0,0,0.6);
  opacity: 0;
  transform: translateY(12px);
  transition: opacity 0.7s ease 0.35s, transform 0.7s ease 0.35s;
}
.give-hero-tagline.show {
  opacity: 1;
  transform: translateY(0);
}
.word { display: inline-block; opacity: 0; filter: blur(10px); transform: translateY(10px); transition: opacity 0.7s ease, filter 0.7s ease, transform 0.7s ease; }
.word.show { opacity: 1; filter: blur(0); transform: translateY(0); }

/* ── WHITE LIFT ── */
.white-lift {
  position: relative; z-index: 3;
  margin-top: -60px;
  border-radius: 60px 60px 0 0;
  background: var(--white);
  box-shadow: 0 0 10px -5px var(--black);
  overflow: hidden;
}

/* ── SECTION ── */
.section-inner {
  width: 100%; max-width: 1000px;
  margin: 0 auto; padding: 0 40px;
}

/* ── MAIN CONTENT TOP SPACING (tagline moved to hero) ── */
.give-main-top {
  padding-top: 120px;
}
.give-h2 {
  font-family: 'Judson', serif;
  font-size: clamp(32px, 5vw, 80px);
  letter-spacing: -0.04em; line-height: 1em;
  color: var(--black);
}

/* ── 3-COL GIVING CARDS ── */
.give-cards-row {
  display: flex; align-items: flex-start; gap: 50px;
  padding: 0 0 100px;
}
.give-card { flex: 1; display: flex; flex-direction: column; gap: 20px; }
.give-card-img {
  aspect-ratio: 1.333; border-radius: 15px; overflow: hidden;
  box-shadow: 0 0 10px -5px var(--black); background: #eee;
}
.give-card-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.give-card-img-ph {
  width: 100%; height: 100%; min-height: 180px;
  display: flex; align-items: center; justify-content: center;
  color: rgba(0,0,0,0.2); font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
}
.give-h3 {
  font-family: 'Outfit', sans-serif; font-weight: 400;
  font-size: clamp(22px, 2.5vw, 40px);
  letter-spacing: -0.03em; line-height: 0.9em;
}
.give-body {
  font-family: 'Outfit', sans-serif; font-weight: 400;
  font-size: clamp(15px, 1.5vw, 21px);
  letter-spacing: -0.02em; line-height: 1.4em;
  color: var(--black);
}
.give-addr {
  font-family: 'Outfit', sans-serif; font-weight: 300;
  font-size: clamp(18px, 2vw, 28px);
  letter-spacing: -0.02em; line-height: 1.1em;
  color: var(--black);
}

/* ── CASHAPP BUTTON ── */
.cashapp-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  text-decoration: none;
  align-self: flex-start;
  border-radius: 16px;
  transition: box-shadow 0.25s ease;
  position: relative;
}
.cashapp-btn::after {
  content: '';
  display: block;
  height: 1.5px;
  width: 0;
  background: var(--black);
  border-radius: 2px;
  transition: width 0.3s ease;
}
.cashapp-btn:hover {
  box-shadow: 0 8px 32px rgba(0,0,0,0.15);
}
.cashapp-btn:hover::after {
  width: 100%;
}
.cashapp-btn img {
  display: block;
  height: 52px;
  width: auto;
  border-radius: 16px;
}
.cashapp-tag {
  font-family: 'Outfit', sans-serif; font-weight: 400;
  font-size: 13px; letter-spacing: -0.01em; color: var(--gray);
}

/* ── UNDERLINE LINK ── */
.ulink {
  display: inline-flex; align-items: center; gap: 10px;
  font-size: 16px; font-weight: 400; letter-spacing: -0.02em;
  color: var(--black); text-decoration: none;
  position: relative; padding-bottom: 3px;
  width: fit-content;
}
.ulink::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 100%;
  height: 1px; background: var(--black); transition: right 0.3s ease;
}
.ulink:hover::after { right: 0; }
.ucircle {
  width: 20px; height: 20px; border-radius: 50%;
  border: 2px solid rgba(0,0,0,0.6);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: transform 0.2s;
}
.ulink:hover .ucircle { transform: scale(1.2); }

/* ── THANK YOU ROW ── */
.give-thanks-row {
  display: flex; align-items: center; gap: 100px;
  padding: 50px 0 150px;
  background: var(--bg);
}
.give-thanks-text { flex: 1; display: flex; flex-direction: column; gap: 25px; }
.give-thanks-img {
  aspect-ratio: 1.625; border-radius: 30px; overflow: hidden;
  box-shadow: 0 0 10px -5px var(--black); background: #eee;
  flex: 1.3 0 0; width: 0;
}
.give-thanks-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.give-thanks-img-ph {
  width: 100%; height: 100%; min-height: 300px;
  display: flex; align-items: center; justify-content: center;
  color: rgba(0,0,0,0.2); font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
}
.accent-text { color: var(--accent); }

/* ── SECTION GRAY ── */
.section-gray { background: var(--bg); padding: 80px 0 0; }

/* ── REVEAL ── */
.reveal { opacity: 0; transform: translateY(50px); transition: opacity 0.8s ease, transform 0.8s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
.d1 { transition-delay: 0.1s; }
.d2 { transition-delay: 0.2s; }

/* ── RESPONSIVE ── */
@@media (max-width: 900px) {
  .section-inner { padding: 0 25px; }
  .give-cards-row { flex-direction: column; }
  .give-thanks-row { flex-direction: column; gap: 40px; }
  .give-thanks-img { width: 100%; flex: none; }
}
@@media (max-width: 600px) {
  .white-lift { border-radius: 30px 30px 0 0; }
  .give-main-top { padding-top: 80px; }
}
</style>
}

<!-- HERO -->
<section class="give-hero-section" aria-label="Give">
  <div class="give-hero-bg-wrap" id="giveHeroBg">
    <video
      class="give-hero-video"
      src="@Url.Content("~/videos/give.mp4")"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="@Url.Content("~/images/IMG_7706.jpg")"
      aria-hidden="true"></video>
    <div class="give-hero-overlay" aria-hidden="true"></div>
  </div>
  <div class="give-hero-text-wrap">
    <div class="give-hero-text-inner">
      <h1 class="give-hero-title"><span class="word"><strong>Give</strong></span></h1>
      <p class="give-hero-tagline">Your generosity helps us grow.</p>
    </div>
  </div>
</section>

<!-- WHITE LIFT -->
<div class="white-lift">

  <!-- 3-COL GIVING CARDS -->
  <div class="section-inner give-main-top">
    <div class="give-cards-row">

      <!-- Card 1: Give Online via Cash App -->
      <div class="give-card reveal">
        <div class="give-card-img">
          <div class="give-card-img-ph">Add photo</div>
        </div>
        <h3 class="give-h3">Give online.</h3>
        <p class="give-body">The quickest way to give is through Cash App. Tap below to send a gift directly to the pastor — it takes just a few seconds.</p>
        <p class="cashapp-tag">Pastor's Cash App: <strong>@church.CashAppTag</strong></p>
        <a href="https://cash.app/@church.CashAppTag" target="_blank" rel="noopener noreferrer" class="cashapp-btn">
          <img src="~/icons/cash-app1.png" alt="Give via Cash App">
        </a>
      </div>

      <!-- Card 2: Give by Mail -->
      <div class="give-card reveal d1">
        <div class="give-card-img">
          <div class="give-card-img-ph">Add photo</div>
        </div>
        <h3 class="give-h3">Give by mail.</h3>
        <p class="give-body">To give by mail, simply send a check or cash donation to:</p>
        <p class="give-addr">
          @church.NameText<br>
          @church.Address.Street<br>
          @church.Address.City, @church.Address.State @church.Address.Zip
        </p>
        <p class="give-body">Make checks payable to <em>'New Bethel Missionary Baptist Church'</em>.</p>
      </div>

      <!-- Card 3: Give in Person -->
      <div class="give-card reveal d2">
        <div class="give-card-img">
          <div class="give-card-img-ph">Add photo</div>
        </div>
        <h3 class="give-h3">Give in person.</h3>
        <p class="give-body">You're welcome to give in person during our regular gatherings. Cash and check donations can be placed securely at our giving desk.</p>
      </div>

    </div>
  </div>

  <!-- THANK YOU ROW -->
  <div class="section-gray">
    <div class="section-inner">
      <div class="give-thanks-row reveal">
        <div class="give-thanks-text">
          <h3 class="give-h3">Thank you for your <span class="accent-text"><strong>Generosity.</strong></span></h3>
          <p class="give-body">We thank you for all your generous giving. Your generosity helps us carry out the mission of New Bethel Missionary Baptist Church — to love God, build community, and reach our city with the message of Jesus.</p>
        </div>
        <div class="give-thanks-img">
          <div class="give-thanks-img-ph">Add photo</div>
        </div>
      </div>
    </div>
  </div>

</div><!-- end white-lift -->

@section Scripts {
<script src="~/js/hero-video-env.js" asp-append-version="true"></script>
<script>
  // Hero word blur-in
  window.addEventListener('load', () => {
    const words = document.querySelectorAll('.word');
    words.forEach((w, i) => setTimeout(() => w.classList.add('show'), 300 + i * 150));
    const tag = document.querySelector('.give-hero-tagline');
    if (tag) setTimeout(() => tag.classList.add('show'), 450);
  });

  // Hero video: keep muted + play() for browsers that ignore autoplay; fallback if file missing
  (function () {
    const wrap = document.getElementById('giveHeroBg');
    const v = document.querySelector('.give-hero-video');
    if (!wrap || !v) return;
    if (typeof window.skipHeavyHeroVideo === 'function' && window.skipHeavyHeroVideo()) {
      v.pause();
      v.removeAttribute('src');
      v.load();
      wrap.classList.add('is-fallback');
      return;
    }
    v.muted = true;
    v.defaultMuted = true;
    v.setAttribute('muted', '');
    const tryPlay = function () { v.play().catch(function () {}); };
    v.addEventListener('loadeddata', tryPlay, { once: true });
    v.addEventListener('canplay', tryPlay, { once: true });
    tryPlay();
    v.addEventListener('error', function () {
      wrap.classList.add('is-fallback');
    }, { once: true });
  })();

  // Parallax hero
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    const bg = document.querySelector('.give-hero-video');
    if (bg) bg.style.transform = `translateY(${y * 0.3}px)`;
    const txt = document.querySelector('.give-hero-text-wrap');
    if (txt) txt.style.transform = `translateY(${y * 0.15}px)`;
  }, { passive: true });

  // Scroll reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
}
