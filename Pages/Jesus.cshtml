@page
@using ChurchWebsite.Models
@using Microsoft.Extensions.Options
@inject IOptions<ChurchSettings> ChurchOptions
@{
    Layout = "_Layout";
    ViewData["Title"] = "Jesus";
    var church = ChurchOptions.Value;
    var watchIsExternal = !string.IsNullOrWhiteSpace(church.SocialMedia.YouTube);
    var watchUrl = watchIsExternal ? church.SocialMedia.YouTube! : "#";
}

@section Head {
<meta name="description" content="Learn about who Jesus is, what He taught, and what it means to follow Him at New Bethel Missionary Baptist Church.">
<link rel="preload" as="video" type="video/mp4" href="~/videos/risencross.mp4" asp-append-version="true" />
<style>
/* ── TOKENS ── */
:root {
  --white: #ffffff;
  --bg: #ededed;
  --black: #000000;
  --accent: #2a967d;
  --gray: #949494;
  --gray-dark: #474747;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
body { font-family: 'Outfit', sans-serif; background: var(--bg); color: var(--black); overflow-x: hidden; }

/* ── HERO (bg wrap + video + overlay + text layer — same model as /Give and home) ── */
.jesus-hero-section {
  --jesus-hero-h: 75vh;
  --jesus-hero-minh: 500px;
  position: relative;
  width: 100%;
  background: #000;
}
.jesus-hero-bg-wrap {
  width: 100%;
  height: var(--jesus-hero-h);
  min-height: var(--jesus-hero-minh);
  position: relative;
  overflow: hidden;
  background: #000;
}
.jesus-hero-bg-wrap.is-fallback {
  background: linear-gradient(160deg, #0d1a12 0%, #112218 50%, #0d1a12 100%);
}
.jesus-hero-bg-wrap.is-fallback .jesus-hero-video {
  display: none;
}
.jesus-hero-video {
  position: absolute;
  inset: 0;
  z-index: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  pointer-events: none;
  will-change: transform;
}
.jesus-hero-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: rgba(0, 0, 0, 0.38);
  pointer-events: none;
}
.jesus-hero-text-wrap {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: var(--jesus-hero-h);
  min-height: var(--jesus-hero-minh);
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}
.jesus-hero-text {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 900px;
  padding: 0 24px;
}
.jesus-hero-title {
  font-family: 'Judson', serif; font-style: italic;
  font-size: clamp(80px, 15vw, 240px);
  letter-spacing: -0.06em; line-height: 0.85em;
  color: var(--white);
  text-shadow: 0 0 50px rgba(0,0,0,0.5);
}
.jesus-hero-title strong { font-style: normal; font-weight: 700; }
.word { display: inline-block; opacity: 0; filter: blur(10px); transform: translateY(10px); transition: opacity 0.7s ease, filter 0.7s ease, transform 0.7s ease; }
.word.show { opacity: 1; filter: blur(0); transform: translateY(0); }

/* ── WHITE LIFT ── */
.white-lift {
  position: relative; z-index: 3;
  margin-top: -60px;
  border-radius: 60px 60px 0 0;
  background: var(--white);
  box-shadow: 0 0 10px -5px var(--black);
  overflow: hidden;
}

/* ── SECTION ── */
.section-inner {
  width: 100%; max-width: 1000px;
  margin: 0 auto; padding: 0 40px;
}

/* ── INTRO ── */
.jesus-intro-wrap {
  padding: 120px 0 80px;
}
.jesus-intro-row {
  display: flex; align-items: flex-start; gap: 80px;
}
.jesus-intro-left { flex: 1.2 0 0; }
.jesus-intro-right { flex: 1 0 0; display: flex; flex-direction: column; gap: 20px; padding-top: 8px; }
.jesus-h2 {
  font-family: 'Judson', serif;
  font-size: clamp(32px, 5vw, 72px);
  letter-spacing: -0.04em; line-height: 0.95em;
  color: var(--black);
}
.jesus-body {
  font-family: 'Outfit', sans-serif; font-weight: 400;
  font-size: clamp(15px, 1.5vw, 19px);
  letter-spacing: -0.02em; line-height: 1.5em;
  color: var(--black);
}
.accent-text { color: var(--accent); }

/* ── FAQ / ACCORDION ── */
.faq-wrap {
  padding: 0 0 100px;
}
.faq-item {
  border-top: 1px solid rgba(0,0,0,0.12);
}
.faq-item:last-child { border-bottom: 1px solid rgba(0,0,0,0.12); }
.faq-trigger {
  width: 100%; display: flex; align-items: center; justify-content: space-between;
  gap: 20px;
  padding: 28px 0;
  background: none; border: none; cursor: pointer; text-align: left;
}
.faq-question {
  font-family: 'Outfit', sans-serif; font-weight: 400;
  font-size: clamp(18px, 2vw, 28px);
  letter-spacing: -0.03em; line-height: 1.1em;
  color: var(--black);
}
.faq-icon {
  width: 28px; height: 28px; flex-shrink: 0;
  border: 1.5px solid rgba(0,0,0,0.4); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  transition: transform 0.3s, background 0.3s, border-color 0.3s;
}
.faq-icon svg { transition: transform 0.3s; }
.faq-item.open .faq-icon { background: var(--black); border-color: var(--black); }
.faq-item.open .faq-icon svg { transform: rotate(45deg); }
.faq-icon svg line { stroke: var(--black); transition: stroke 0.3s; }
.faq-item.open .faq-icon svg line { stroke: var(--white); }
.faq-body {
  overflow: hidden; max-height: 0;
  transition: max-height 0.45s ease, padding 0.3s ease;
  padding: 0 0 0;
}
.faq-body-inner {
  font-family: 'Outfit', sans-serif; font-weight: 300;
  font-size: clamp(15px, 1.5vw, 18px);
  letter-spacing: -0.01em; line-height: 1.6em;
  color: var(--gray-dark);
  padding-bottom: 28px;
  max-width: 780px;
}
.faq-body-inner p + p { margin-top: 14px; }

/* ── TAKE A NEXT STEP — same destinations as header: Events, Watch ── */
.jesus-join-wrap {
  background: var(--bg);
  padding: 80px 0 140px;
}
.jesus-join-heading {
  font-family: 'Judson', serif; font-style: italic;
  font-size: clamp(24px, 3vw, 48px);
  letter-spacing: -0.04em; line-height: 1em;
  color: var(--black); margin-bottom: 50px;
}
.jesus-join-heading strong { font-style: normal; }
.jesus-next-nav {
  list-style: none; margin: 0; padding: 0;
  display: flex; flex-direction: column; gap: 16px;
  max-width: 720px;
}
.jesus-next-link {
  display: flex; align-items: center; gap: 20px;
  padding: 22px 24px 22px 20px;
  border-radius: 20px; text-decoration: none; color: inherit;
  background: var(--white);
  box-shadow: 0 0 8px -4px rgba(0,0,0,0.35);
  border: 1px solid rgba(0,0,0,0.06);
  transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
}
.jesus-next-link:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 36px -12px rgba(0,0,0,0.3);
  border-color: rgba(42, 150, 125, 0.35);
}
.jesus-next-link:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 3px;
}
.jesus-next-icon {
  width: 52px; height: 52px; flex-shrink: 0; border-radius: 14px;
  background: rgba(42, 150, 125, 0.12);
  color: var(--accent);
  display: flex; align-items: center; justify-content: center;
}
.jesus-next-icon svg { display: block; }
.jesus-next-text { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6px; }
.jesus-next-title {
  font-family: 'Judson', serif;
  font-size: clamp(20px, 2.2vw, 32px);
  letter-spacing: -0.03em; line-height: 1.1;
  color: var(--black);
}
.jesus-next-sub {
  font-family: 'Outfit', sans-serif; font-size: clamp(14px, 1.2vw, 16px);
  font-weight: 400; letter-spacing: -0.01em; line-height: 1.45;
  color: var(--gray-dark);
}
.jesus-next-nav-hint {
  display: block; margin-top: 2px;
  font-size: 12px; letter-spacing: 0.02em; color: var(--gray);
}
.jesus-next-chevron {
  flex-shrink: 0; color: var(--black); opacity: 0.45;
  transition: transform 0.2s, opacity 0.2s;
}
.jesus-next-link:hover .jesus-next-chevron { transform: translateX(4px); opacity: 0.9; }

/* ── REVEAL ── */
.reveal { opacity: 0; transform: translateY(50px); transition: opacity 0.8s ease, transform 0.8s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
.d1 { transition-delay: 0.15s; }
.d2 { transition-delay: 0.3s; }

/* ── RESPONSIVE ── */
@@media (max-width: 900px) {
  .section-inner { padding: 0 25px; }
  .jesus-intro-row { flex-direction: column; gap: 30px; }
}
@@media (max-width: 600px) {
  .white-lift { border-radius: 30px 30px 0 0; }
  .jesus-intro-wrap { padding: 80px 0 50px; }
  .faq-trigger { padding: 20px 0; }
}
</style>
}

<!-- HERO -->
<section class="jesus-hero-section" aria-label="Jesus">
  <div class="jesus-hero-bg-wrap" id="jesusHeroBg">
    <video
      class="jesus-hero-video"
      src='@Url.Content("~/videos/risencross.mp4")'
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"></video>
    <div class="jesus-hero-overlay" aria-hidden="true"></div>
  </div>
  <div class="jesus-hero-text-wrap">
    <div class="jesus-hero-text">
      <h1 class="jesus-hero-title"><span class="word"><strong>Jesus</strong></span></h1>
    </div>
  </div>
</section>

<!-- WHITE LIFT -->
<div class="white-lift">

  <!-- INTRO -->
  <div class="jesus-intro-wrap">
    <div class="section-inner">
      <div class="jesus-intro-row reveal">
        <div class="jesus-intro-left">
          <h2 class="jesus-h2">We're all about <span class="accent-text">Jesus.</span></h2>
        </div>
        <div class="jesus-intro-right">
          <p class="jesus-body">At New Bethel, everything we do centers on the person of Jesus Christ. We believe He is the Son of God — fully human and fully divine — who came to earth, lived a sinless life, died on the cross for our sins, and rose again on the third day.</p>
          <p class="jesus-body">Whether you're exploring faith for the first time or have been walking with Christ for years, we'd love to journey with you.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- FAQ ACCORDION -->
  <div class="faq-wrap">
    <div class="section-inner">

      <div class="faq-item reveal">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">The life of Jesus</span>
          <span class="faq-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div class="faq-body">
          <div class="faq-body-inner">
            <p>Jesus was born in Bethlehem over 2,000 years ago to a virgin named Mary. He grew up in Nazareth, was baptized by John the Baptist, and spent about three years teaching, healing, and proclaiming the Kingdom of God.</p>
            <p>He performed countless miracles — healing the sick, raising the dead, and demonstrating His authority over nature. He called twelve disciples and poured His life into them, modeling what it means to love God and serve others.</p>
          </div>
        </div>
      </div>

      <div class="faq-item reveal d1">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">The message of Jesus</span>
          <span class="faq-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div class="faq-body">
          <div class="faq-body-inner">
            <p>Jesus proclaimed the Good News of the Kingdom of God — that through Him, humanity could be reconciled to God and experience life as it was always meant to be.</p>
            <p>He summarized the entire law with two commands: love God with everything you have, and love your neighbor as yourself. His teachings on grace, forgiveness, justice, and mercy continue to transform lives around the world today.</p>
          </div>
        </div>
      </div>

      <div class="faq-item reveal d2">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">Jesus' death and resurrection</span>
          <span class="faq-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div class="faq-body">
          <div class="faq-body-inner">
            <p>Jesus was crucified on a cross — not because He did anything wrong, but because He willingly took the punishment our sin deserves. His death is the ultimate act of love and the foundation of our salvation.</p>
            <p>Three days later, He rose from the dead. The resurrection is the cornerstone of the Christian faith. It confirms that Jesus is who He said He is, that sin and death have been defeated, and that new life is available to all who believe.</p>
          </div>
        </div>
      </div>

      <div class="faq-item reveal">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">Following Jesus</span>
          <span class="faq-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div class="faq-body">
          <div class="faq-body-inner">
            <p>Following Jesus is a daily, ongoing relationship — not just a one-time decision. It means trusting Him with your whole life, reading His word, praying, and being part of a community of believers who encourage one another.</p>
            <p>At New Bethel, we walk this journey together. We believe the Church is meant to be a family where everyone belongs, grows, and is sent out to make a difference in the world.</p>
          </div>
        </div>
      </div>

      <div class="faq-item reveal d1">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">Where do I start?</span>
          <span class="faq-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div class="faq-body">
          <div class="faq-body-inner">
            <p>The best place to start is simply showing up. Come to one of our Sunday services, meet the family, and hear the message for yourself. No matter where you are in your faith journey, you are welcome here.</p>
            <p>If you want to take a next step — whether you'd like to be baptized, join a small group, or just have a conversation — reach out to us and we'd love to connect with you personally.</p>
          </div>
        </div>
      </div>

    </div>
  </div>

</div><!-- end white-lift -->

<!-- TAKE A NEXT STEP — same targets as header nav: Events, Watch -->
<div class="jesus-join-wrap">
  <div class="section-inner">
    <h2 class="jesus-join-heading reveal"><strong>Take a next step.</strong></h2>
    <p class="reveal" style="font-family:'Outfit',sans-serif; font-size: clamp(15px,1.4vw,18px); color: var(--gray-dark); max-width: 720px; margin: -32px 0 28px; line-height: 1.5;">The same quick links you’ll find in the site menu at the top of the page.</p>
    <nav class="jesus-next-nav" aria-label="Upcoming events and online worship">
      <a href="/Events" class="jesus-next-link reveal">
        <span class="jesus-next-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <path d="M3 10h18M8 2v4M16 2v4"/>
          </svg>
        </span>
        <span class="jesus-next-text">
          <span class="jesus-next-title">Events</span>
          <span class="jesus-next-sub">View upcoming services, gatherings, and what’s on the calendar at New Bethel.</span>
          <span class="jesus-next-nav-hint">Same page as <strong>Events</strong> in the top menu</span>
        </span>
        <span class="jesus-next-chevron" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
        </span>
      </a>
      <a href="@watchUrl" class="jesus-next-link reveal d1" @Html.Raw(watchIsExternal ? "target=\"_blank\" rel=\"noopener noreferrer\"" : "")>
        <span class="jesus-next-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M8 5v14l11-7-11-7z"/>
          </svg>
        </span>
        <span class="jesus-next-text">
          <span class="jesus-next-title">Watch</span>
          <span class="jesus-next-sub">Sermons, messages, and worship on our YouTube channel—wherever you are.</span>
          <span class="jesus-next-nav-hint">Same link as <strong>Watch</strong> in the top menu</span>
        </span>
        <span class="jesus-next-chevron" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
        </span>
      </a>
    </nav>
  </div>
</div>

@section Scripts {
<script src="~/js/hero-video-env.js" asp-append-version="true"></script>
<script>
  // Hero word blur-in — DOM ready, not window load (same as home / About)
  (function () {
    const words = document.querySelectorAll('.jesus-hero-section .word');
    if (!words.length) return;
    const run = () => {
      words.forEach((w, i) => setTimeout(() => w.classList.add('show'), 300 + i * 150));
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      run();
    }
  })();

  // Hero video: keep muted + play() for browsers that ignore autoplay; fallback if file missing
  (function () {
    const wrap = document.getElementById('jesusHeroBg');
    const v = document.querySelector('.jesus-hero-video');
    if (!wrap || !v) return;
    if (typeof window.skipHeavyHeroVideo === 'function' && window.skipHeavyHeroVideo()) {
      v.pause();
      v.removeAttribute('src');
      v.load();
      wrap.classList.add('is-fallback');
      return;
    }
    v.muted = true;
    v.defaultMuted = true;
    v.setAttribute('muted', '');
    const tryPlay = function () { v.play().catch(function () {}); };
    v.addEventListener('loadeddata', tryPlay, { once: true });
    v.addEventListener('canplay', tryPlay, { once: true });
    tryPlay();
    v.addEventListener('error', function () {
      wrap.classList.add('is-fallback');
    }, { once: true });
  })();

  // Parallax hero
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    const bg = document.querySelector('.jesus-hero-video');
    if (bg) bg.style.transform = `translateY(${y * 0.3}px)`;
    const txt = document.querySelector('.jesus-hero-text-wrap');
    if (txt) txt.style.transform = `translateY(${y * 0.15}px)`;
  }, { passive: true });

  // Accordion
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const body = item.querySelector('.faq-body');
      const isOpen = item.classList.contains('open');

      // Close all
      document.querySelectorAll('.faq-item.open').forEach(openItem => {
        openItem.classList.remove('open');
        openItem.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');
        openItem.querySelector('.faq-body').style.maxHeight = '0';
      });

      // Open clicked (if it was closed)
      if (!isOpen) {
        item.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
        body.style.maxHeight = body.scrollHeight + 'px';
      }
    });
  });

  // Scroll reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
}
